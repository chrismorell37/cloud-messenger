VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_APP_PASSWORD=your_shared_password
RESEND_API_KEY=your_resend_api_key
OPENAI_API_KEY=your_openai_api_key

# Chat mode (iMessage-style) - user display names
VITE_USER1_NAME=User 1
VITE_USER2_NAME=User 2

# Cloudflare CDN (optional - for caching media to reduce Supabase egress)
VITE_CDN_URL=https://your-worker.workers.dev

# Spotify Add to playlist (optional)
# Create an app at https://developer.spotify.com/dashboard and add redirect URI: https://your-domain/api/spotify-callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Supabase service role key (for Spotify token storage only; never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
